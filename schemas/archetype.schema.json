{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foresight/archetype/v1.1",
  "title": "Foresight archetype",
  "description": "Validates a Foresight archetype file (e.g. archetype.ecommerce.json): the durable, transferable standard a Verifier scores a repo against. Note: this schema validates structure only. Stable-id uniqueness is checked by schemas/validate.mjs, not here.",
  "type": "object",
  "required": ["archetype", "version", "applies_when", "goal_definition", "checkpoints"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "_readme": { "type": "object" },
    "archetype": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semver. Archetypes are versioned; checkpoints are never silently renamed."
    },
    "applies_when": { "type": "string", "minLength": 1 },
    "goal_definition": {
      "type": "object",
      "required": ["shippable", "great"],
      "additionalProperties": false,
      "properties": {
        "shippable": { "type": "string" },
        "great": { "type": "string" },
        "honest_ceiling": { "type": "string" }
      }
    },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/checkpoint" }
    }
  },
  "$defs": {
    "checkpoint": {
      "type": "object",
      "required": ["id", "domain", "severity", "confidence", "title", "why", "levels", "verify"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$",
          "description": "Stable, namespaced, permanent contract (e.g. ec.checkout.atomic_stock_hold). Version the archetype; never rename a checkpoint."
        },
        "domain": { "enum": ["backbone", "design"] },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "confidence": { "enum": ["established", "reasoned", "taste_limited"] },
        "title": { "type": "string", "minLength": 1 },
        "why": { "type": "string", "minLength": 1 },
        "levels": {
          "type": "object",
          "required": ["3", "6", "9"],
          "additionalProperties": false,
          "properties": {
            "3": { "type": "string", "minLength": 1 },
            "6": { "type": "string", "minLength": 1 },
            "9": { "type": "string", "minLength": 1 }
          }
        },
        "verify": {
          "type": "object",
          "required": ["reasoning"],
          "additionalProperties": false,
          "properties": {
            "reasoning": { "type": "string", "minLength": 1 },
            "assertions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["check", "type"],
                "additionalProperties": false,
                "properties": {
                  "check": { "type": "string", "minLength": 1 },
                  "type": { "enum": ["static", "test", "runtime"] }
                }
              }
            }
          }
        }
      }
    }
  }
}
