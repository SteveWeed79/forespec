{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foresight/archetype-design/v2",
  "title": "Foresight instrumented design archetype",
  "description": "Validates an instrumented design archetype (e.g. archetype.ecommerce.design.json): design checkpoints decomposed into weighted sub-signals that compute a 0-10 composite. Note: structure only. Per-checkpoint signal weights summing to 1.0 and id uniqueness are checked by schemas/validate.mjs.",
  "type": "object",
  "required": ["archetype", "dimension", "version", "checkpoints"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "_readme": { "type": "object" },
    "archetype": { "type": "string", "minLength": 1 },
    "dimension": { "const": "design" },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/instrumentedCheckpoint" }
    },
    "_closing_honesty": { "type": "string" }
  },
  "$defs": {
    "instrumentedCheckpoint": {
      "type": "object",
      "required": ["id", "domain", "severity", "title", "claim_being_quantified", "signals", "residual_risk_overall"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$" },
        "domain": { "const": "design" },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "title": { "type": "string", "minLength": 1 },
        "claim_being_quantified": { "type": "string", "minLength": 1 },
        "_note": { "type": "string" },
        "signals": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/signal" }
        },
        "residual_risk_overall": { "type": "string", "minLength": 1 }
      }
    },
    "signal": {
      "type": "object",
      "required": ["id", "weight", "measurement_type", "what", "scoring", "residual_risk"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "measurement_type": { "enum": ["computed", "model_scored", "boolean", "residual"] },
        "what": { "type": "string", "minLength": 1 },
        "scoring": { "type": "string", "minLength": 1 },
        "residual_risk": { "type": "string", "minLength": 1 }
      }
    }
  }
}
