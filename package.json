{
  "name": "foresight-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Foresight — forces domain foresight before a feature, then verifies what got built against it.",
  "keywords": [
    "foresight",
    "verifier",
    "code-review",
    "security",
    "ci",
    "pr-gate",
    "github-action",
    "archetype",
    "checkpoints",
    "ai",
    "llm-safety",
    "backend",
    "correctness"
  ],
  "homepage": "https://github.com/SteveWeed79/glowing-barnacle#readme",
  "bugs": {
    "url": "https://github.com/SteveWeed79/glowing-barnacle/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SteveWeed79/glowing-barnacle.git"
  },
  "author": "Steve Weed",
  "license": "BUSL-1.1",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "foresight": "bin/foresight.mjs"
  },
  "files": [
    "bin/",
    "repo-verify/*.mjs",
    "verifier-eval/adapters/*.mjs",
    "library/",
    "schemas/",
    "archetype.*.json",
    "action.yml"
  ],
  "optionalDependencies": {
    "playwright-core": "^1.40.0"
  },
  "scripts": {
    "check": "node schemas/validate.mjs",
    "eval": "node verifier-eval/run-eval.mjs",
    "eval:claude": "node verifier-eval/run-eval.mjs --adapter claude --out verifier-eval/report.json",
    "init": "node bin/foresight.mjs init",
    "detect": "node repo-verify/detect.mjs",
    "plan": "node repo-verify/plan.mjs",
    "design": "node repo-verify/design-probe.mjs",
    "verify": "node repo-verify/verify.mjs",
    "verify:self": "node repo-verify/self-test.mjs",
    "feedback": "node repo-verify/feedback.mjs",
    "calibrate": "node repo-verify/calibrate.mjs",
    "proficiency": "node repo-verify/proficiency.mjs",
    "gate": "node repo-verify/pr-gate.mjs",
    "license:bump": "node scripts/bump-change-date.mjs",
    "version": "node scripts/bump-change-date.mjs && git add LICENSE",
    "prepublishOnly": "node repo-verify/self-test.mjs"
  }
}
