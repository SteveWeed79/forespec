# Node
node_modules/
npm-debug.log*
*.log

# Local env files (NEVER commit your API key)
.env
.env.local

# Forespec calibration store (contains local instance data — never commit)
.foresight/

# Forespec per-project artifacts — generated when the tool runs against a repo. This IS the
# tool's repo, not a graded project, so test runs must not leave these behind. (In a real
# consumer project you DO commit foresight.config.json.)
/foresight.config.json
/forespec-plan.md
/forespec-plan.bak.md
